{
  "name": "mcp-fiorilli-transparencia",
  "version": "1.0.0",
  "description": "MCP Server para Portais de Transparência que utilizam o sistema Fiorilli SCPI. Acessa dados públicos de despesas, receitas, pessoal, licitações, contratos e transferências de qualquer município que use o software Fiorilli.",
  "main": "dist/index.js",
  "bin": {
    "mcp-fiorilli-transparencia": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test \"test/**/*.test.mjs\"",
    "test:unit": "node --test \"test/**/*.test.mjs\"",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "inspector": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "transparencia",
    "fiorilli",
    "governo",
    "brasil",
    "prefeitura",
    "dados-abertos"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^12.9.0",
    "node-fetch": "^3.3.2",
    "unpdf": "^1.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
